{
  "name": "n8n-nodes-syncro-crm",
  "version": "1.0.0",
  "description": "N8N community node for Syncro CRM — create leads, update stages and manage campaigns",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://app.syncro.chat",
  "author": {
    "name": "Syncro CRM"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/matheusrossidev/crmlaravel"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && copyfiles -u 0 \"nodes/**/*.svg\" dist/",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SyncroCrmApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SyncroCrm/SyncroCrm.node.js"
    ]
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "n8n-workflow": "^1.0.0",
    "copyfiles": "^2.4.1"
  }
}
